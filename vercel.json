{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": ".output/public",
  "installCommand": "npm ci",
  "env": {
    "NODE_ENV": "production",
    "SHOPIFY_STOREFRONT_TOKEN": "997533fd82ffe57f640986f050aa1be6",
    "SHOPIFY_STORE_DOMAIN": "loudmouf-launchpad-buagl.myshopify.com"
  },
